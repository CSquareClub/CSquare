# Core app
DATABASE_URL=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=

# Google service account (server-side only)
# Option 1: Provide fields individually
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep escaped newlines in one line, for example:
# -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Option 2: Provide the full JSON object as a single env value
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Use this when integrating with Google Sheets/Drive APIs
GOOGLE_SPREADSHEET_ID=
