# Core app
DATABASE_URL=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=

# Google service account (server-side only)
# Option 1: Provide fields individually
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep escaped newlines in one line, for example:
# -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Safer alternative: base64-encoded private key string.
# If set, this takes precedence over GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=

# Option 2: Provide the full JSON object as a single env value
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option 3 (most robust on hosting UIs): base64-encoded full JSON service account.
# If set, this takes precedence over GOOGLE_SERVICE_ACCOUNT_JSON and split vars.
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Use one shared spreadsheet for all tracks
GOOGLE_SPREADSHEET_ID=

# Or use separate spreadsheets per track (preferred)
GOOGLE_SPREADSHEET_ID_2026=
GOOGLE_SPREADSHEET_ID_2027=

# Outside-CU join registrations sync sheet
# If set, admin Campus Ambassador tab sync will write two tabs:
# - Outside Registrations
# - Campus Ambassadors
GOOGLE_SPREADSHEET_ID_OUTSIDE=

# Public gallery links for C Square Moments (no DB required for website display)
# Supports comma-separated or newline-separated links.
# You can also use: Title|DriveLink
# Example:
# NEXT_PUBLIC_MOMENTS_DRIVE_LINKS=Hackathon Day 1|https://drive.google.com/file/d/FILE_ID/view,https://drive.google.com/open?id=FILE_ID_2
NEXT_PUBLIC_MOMENTS_DRIVE_LINKS=
